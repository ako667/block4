BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/your_infura_project_id
DEPLOYER_ADDRESS=0xYourDeployerAddress

INFURA_API_KEY=your_infura_project_id

MAINNET_RPC=https://mainnet.infura.io/v3/your_infura_project_id
SEPOLIA_RPC=https://sepolia.infura.io/v3/your_infura_project_id
ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia.infura.io/v3/your_infura_project_id
OPTIMISM_SEPOLIA_RPC=https://optimism-sepolia.infura.io/v3/your_infura_project_id

# Required for Base Sepolia deploy (scripts/deploy-base-sepolia.sh)
# MetaMask → account → Export private key (use a dedicated test wallet)
PRIVATE_KEY=0xYourPrivateKeyWithoutQuotes

# Optional — only for automatic forge --verify (deploy works without these)
# Option 1: https://basescan.org/myapikey (if the site lets you create a key)
BASESCAN_API_KEY=
# Option 2: https://etherscan.io/myapikey — same Etherscan API v2, works for Base Sepolia (chain 84532)
ETHERSCAN_API_KEY=
